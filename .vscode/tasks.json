{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "firebase: emulators",
      "type": "shell",
      "command": "zsh -lc 'source ~/.nvm/nvm.sh && nvm use 20 && firebase emulators:start --import=./emulator-data --export-on-exit=./emulator-data'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "firebase: deploy functions",
      "type": "shell",
      "command": "firebase deploy --only functions",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "detail": "firebase deploy --only functions",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "firebase: deploy rules",
      "type": "shell",
      "command": "firebase deploy --only firestore:rules,storage",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "detail": "firebase deploy --only firestore:rules,storage"
    }
  ]
}
