{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "scripts": {
    "test": "node --test test/booking.util.test.js",
    "test:rules": "cd .. && firebase emulators:exec --only firestore,storage \"cd functions && node --test test/rules.test.js\"",
    "backfill:booking-ranges": "node scripts/backfillBookingRanges.js",
    "backfill:pending-booking-counts": "node scripts/backfillPendingBookingCounts.js",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "dependencies": {
    "@google-cloud/tasks": "^5.3.0",
    "crypto": "^1.0.1",
    "dotenv": "^17.2.3",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.6.0",
    "uuid": "^7.0.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "firebase": "^12.12.1",
    "firebase-functions-test": "^3.1.0"
  },
  "private": true
}
