rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isVerificationLevel(level) {
      return level in ['None', 'Basic', 'Full'];
    }

    function currentUserVerification() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.verified;
    }

    function currentUserCanRent() {
      return isSignedIn() && currentUserVerification() in ['Basic', 'Full'];
    }

    function currentUserCanList() {
      return isSignedIn() && currentUserVerification() == 'Full';
    }

    function isValidUserCreate(uid) {
      return isSelf(uid) &&
        request.resource.data.uid == uid &&
        (
          request.resource.data.verified == 'None' ||
          (
            request.resource.data.verified == 'Basic' &&
            request.auth.token.email_verified == true
          )
        );
    }

    function isValidUserSelfUpdate(uid) {
      return isSelf(uid) &&
        isVerificationLevel(request.resource.data.verified) &&
        isValidFullVerificationSelfUpdate() &&
        (
          request.resource.data.verified == resource.data.verified ||
          (
            resource.data.verified == 'None' &&
            request.resource.data.verified == 'Basic' &&
            request.auth.token.email_verified == true
          )
        );
    }

    function isValidFullVerificationSelfUpdate() {
      return !('fullVerification' in request.resource.data) ||
        request.resource.data.fullVerification == resource.data.fullVerification ||
        (
          request.resource.data.fullVerification.keys().hasOnly([
            'status',
            'activeSubmissionId',
            'submittedAt',
            'reviewedAt'
          ]) &&
          request.resource.data.fullVerification.status == 'Pending' &&
          request.resource.data.fullVerification.activeSubmissionId is string &&
          request.resource.data.fullVerification.submittedAt is timestamp &&
          request.resource.data.fullVerification.reviewedAt == null &&
          existsAfter(/databases/$(database)/documents/verificationSubmissions/$(request.resource.data.fullVerification.activeSubmissionId)) &&
          getAfter(/databases/$(database)/documents/verificationSubmissions/$(request.resource.data.fullVerification.activeSubmissionId)).data.userId == request.auth.uid &&
          getAfter(/databases/$(database)/documents/verificationSubmissions/$(request.resource.data.fullVerification.activeSubmissionId)).data.status == 'Pending'
        );
    }

    function hasPendingVerificationSubmission() {
      return ('fullVerification' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.fullVerification is map &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.fullVerification.status == 'Pending';
    }

    function isValidVerificationSubmissionCreate(submissionId) {
      return isSignedIn() &&
        !hasPendingVerificationSubmission() &&
        request.resource.data.keys().hasOnly([
          'id',
          'userId',
          'phone',
          'address',
          'faceKycStatus',
          'status',
          'submittedAt',
          'reviewedAt'
        ]) &&
        request.resource.data.id == submissionId &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.phone is string &&
        request.resource.data.address is string &&
        request.resource.data.faceKycStatus == 'Submitted' &&
        request.resource.data.status == 'Pending' &&
        request.resource.data.submittedAt is timestamp &&
        request.resource.data.reviewedAt == null &&
        getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.fullVerification.status == 'Pending' &&
        getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.fullVerification.activeSubmissionId == submissionId;
    }

    function isValidVerificationSubmissionAdminUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'reviewedAt']) &&
        request.resource.data.status in ['Pending', 'Approved', 'Rejected'] &&
        (!('reviewedAt' in request.resource.data) ||
          request.resource.data.reviewedAt is timestamp);
    }

    function isValidAssetAudit() {
      return request.resource.data.keys().hasOnly(['type', 'notes', 'createdBy', 'createdAt']) &&
        request.resource.data.type in ['Rejected', 'Edited', 'Approved', 'Deleted'] &&
        request.resource.data.notes is string &&
        request.resource.data.createdBy.uid is string &&
        request.resource.data.createdBy.name is string;
    }

    function isValidReportCreate(reportId) {
      return isSignedIn() &&
        request.resource.data.keys().hasOnly([
          'id',
          'reporterId',
          'reportedUserId',
          'reportType',
          'reason',
          'details',
          'chatId',
          'bookingId',
          'assetId',
          'archiveRequested',
          'bookingCancelRequested',
          'createdAt',
          'status'
        ]) &&
        request.resource.data.id == reportId &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.reportType is string &&
        request.resource.data.reason is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.status == 'Open' &&
        (!('reportedUserId' in request.resource.data) ||
          request.resource.data.reportedUserId is string) &&
        (!('details' in request.resource.data) ||
          request.resource.data.details is string) &&
        (!('chatId' in request.resource.data) ||
          request.resource.data.chatId is string) &&
        (!('bookingId' in request.resource.data) ||
          request.resource.data.bookingId is string) &&
        (!('assetId' in request.resource.data) ||
          request.resource.data.assetId is string) &&
        (!('archiveRequested' in request.resource.data) ||
          request.resource.data.archiveRequested is bool) &&
        (!('bookingCancelRequested' in request.resource.data) ||
          request.resource.data.bookingCancelRequested is bool);
    }

    function isValidReportAdminUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'lastUpdated']) &&
        request.resource.data.status in ['Pending', 'Done'] &&
        (!('lastUpdated' in request.resource.data) ||
          request.resource.data.lastUpdated is timestamp);
    }

    function bookingParticipants(data) {
      return isSignedIn() &&
        (request.auth.uid == data.renter.uid ||
          request.auth.uid == data.asset.owner.uid);
    }

    function bookingIdentityUnchanged() {
      return request.resource.data.id == resource.data.id &&
        request.resource.data.chatId == resource.data.chatId &&
        request.resource.data.asset == resource.data.asset &&
        request.resource.data.renter == resource.data.renter &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.startDate == resource.data.startDate &&
        request.resource.data.endDate == resource.data.endDate &&
        request.resource.data.numDays == resource.data.numDays &&
        request.resource.data.totalPrice == resource.data.totalPrice &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.tokens == resource.data.tokens &&
        request.resource.data.handedOver == resource.data.handedOver &&
        request.resource.data.returned == resource.data.returned &&
        request.resource.data.reviewed == resource.data.reviewed;
    }

    function isChatParticipant(chatId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/userChats/$(request.auth.uid)/chats/$(chatId));
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isValidUserCreate(uid);
      allow update: if isAdmin() || isValidUserSelfUpdate(uid);
      allow delete: if isSelf(uid);

      match /assets/{assetId} {
        allow read: if isSelf(uid) || isAdmin();
        allow write: if isAdmin() || (isSelf(uid) && currentUserCanList());
      }

      match /saved/{assetId} {
        allow read: if isSelf(uid);
        allow write: if isSelf(uid) && currentUserCanRent();
      }

      match /bookings/{bookingId} {
        allow read: if isSelf(uid) || bookingParticipants(resource.data);
        allow create: if false;
        allow update: if isAdmin() || (isSelf(uid) && bookingIdentityUnchanged());
        allow delete: if false;

        match /events/{eventId} {
          allow read: if isSelf(uid);
          allow write: if false;
        }
      }
    }

    match /verificationSubmissions/{submissionId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isValidVerificationSubmissionCreate(submissionId);
      allow update: if isAdmin() && isValidVerificationSubmissionAdminUpdate();
      allow delete: if false;
    }

    match /adminUsers/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isValidReportCreate(reportId);
      allow update: if isAdmin() && isValidReportAdminUpdate();
      allow delete: if false;
    }

    match /accountFeedback/{feedbackId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /assets/{assetId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        currentUserCanList();
      allow update, delete: if isAdmin() ||
        (isSignedIn() && resource.data.ownerId == request.auth.uid && currentUserCanList());

      match /bookings/{bookingId} {
        allow read: if isSignedIn();
        allow create: if false;
        allow update: if isAdmin();
        allow delete: if false;
      }

      match /ratings/{ratingId} {
        allow read: if true;
        allow create: if false;
        allow update, delete: if false;
      }

      match /audits/{auditId} {
        allow read: if isAdmin();
        allow create: if isAdmin() && isValidAssetAudit();
        allow update, delete: if false;
      }
    }

    match /chats/{chatId} {
      allow read: if isAdmin() || isChatParticipant(chatId);
      allow create: if false;
      allow update, delete: if false;

      match /messages/{messageId} {
        allow read: if isAdmin() || isChatParticipant(chatId);
        allow create: if isSignedIn() && isChatParticipant(chatId) && currentUserCanRent();
        allow update, delete: if false;
      }
    }

    match /userChats/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSignedIn() &&
        request.resource.data.keys().hasOnly(['isOnline']);
      allow update: if isSelf(uid);
      allow delete: if false;

      match /chats/{chatId} {
        allow read: if isSelf(uid);
        allow create: if false;
        allow update: if isSignedIn() &&
          (isAdmin() ||
            (currentUserCanRent() &&
              (isSelf(uid) ||
                request.resource.data.lastMessageSenderId == request.auth.uid)));
        allow delete: if isSelf(uid) && currentUserCanRent();
      }
    }
  }
}
